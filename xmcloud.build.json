{
  "authoringPath": "./authoring",
  "renderingHosts": {
    "B2BManufacturing": {
      "path": ".",
      "nodeVersion": "22.22.0",
      "jssDeploymentSecret": "generate",
      "enabled": true,
      "type": "sxa",
      "buildCommand": "build",
      "runCommand": "next:start"
    }
  },
  "postActions": {
    "actions": {
      "warmUpCm": {
        "urls": [
          "/sitecore/shell",
          "/sitecore/client/Applications/Launchpad"
        ]
      }
    }
  }
}
