{
  "authoringPath": "./authoring",
  "deployItems": {
    "modules": [
      "B2BManufacturing"
    ]
  },
  "renderingHosts": {
    "B2BManufacturing": {
      "path": ".",
      "nodeVersion": "22.22.0",
      "jssDeploymentSecret": "generate",
      "enabled": true,
      "type": "sxa",
      "buildCommand": "build",
      "runCommand": "next:start"
    }
  },
  "postActions": {
    "actions": {
      "publish": {
        "path": "/sitecore",
        "languages": ["en"],
        "itemIds": [],
        "targets": ["Edge"],
        "republish": false
      }
    }
  }
}
